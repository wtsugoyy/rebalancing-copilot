# Copy to `.env`, then: powershell -File scripts\start_stack.ps1
#
# ============================================================================
# WHICH BRAIN ANSWERS THE CHAT
# ============================================================================
#   ollama  = local model on this PC. Fully offline; nothing leaves the machine.
#   gateway = any OpenAI-compatible endpoint you point it at.
#             NOTE: this SENDS prompts + tool results (your fund return data) to
#             that endpoint. Deliberate trade-off — do not flip it by accident.
LLM_PROVIDER=ollama

# --- local (LLM_PROVIDER=ollama) --------------------------------------------
# qwen3:14b = reasoning ("thinking") + native tool calling, GPU via native Ollama.
# DO NOT use deepseek-r1: official Ollama builds have no tool-calling template and it
# fabricates numbers instead of calling the engine.
OLLAMA_MODEL=qwen3:14b
# OLLAMA_HOST=http://host.docker.internal:11434

# --- remote gateway (LLM_PROVIDER=gateway) ----------------------------------
# Any OpenAI-compatible /v1/chat/completions endpoint that supports tool calling.
GATEWAY_BASE=https://llm-gateway.example.com
GATEWAY_MODEL=local-main
GATEWAY_PROJECT_KEY=default
GATEWAY_TIMEOUT_S=120
# Leave blank here and put the token in ~/.llm-gateway/bearer.txt (chmod 600),
# or set it directly. Scope it as narrowly as your provider allows.
GATEWAY_BEARER=

# --- Self-hosted Langfuse (offline tracing). UI: http://localhost:3000 ------
LANGFUSE_PUBLIC_KEY=pk-lf-copilot-demo
LANGFUSE_SECRET_KEY=sk-lf-copilot-demo
LANGFUSE_USER_EMAIL=admin@copilot.local
LANGFUSE_USER_PASSWORD=copilot-demo-1234
# LANGFUSE_HOST=http://localhost:3000
# Set to 0 to skip tracing entirely. Worth doing when running the test suite
# without the stack up: the SDK otherwise retries against a server that isn't
# there, which turns a ~35s run into ~10 minutes.
#   LANGFUSE_ENABLED=0 python -m pytest -q
# LANGFUSE_ENABLED=1

# --- Self-hosted Supermemory (offline memory, local embeddings) -------------
# The key is printed on first boot: docker logs supermemory | grep sm_
SUPERMEMORY_URL=http://host.docker.internal:8787
SUPERMEMORY_API_KEY=

# --- Local storage paths ----------------------------------------------------
# Whatever you load stays in these files, and data/ is gitignored. Override only
# if you want state somewhere else (the Docker image points them at /app/data).
# COPILOT_DB=data/copilot.db
# COPILOT_LOG=data/copilot.log
# COPILOT_MEMORY_DB=data/memory.db

# Optional overrides
# LLM_THINK=1
